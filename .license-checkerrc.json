    "GPL",
    "GPLv2",
    "GPLv3",
    "AGPL",
    "AGPLv2",
    "AGPLv3",
    "SSPL",
    "EUPL-1.0",
    "EUPL-1.1",
    "EUPL-1.2"
  ]
}
