{
  "production": true,
  "onlyAllow": [
    "MIT",
    "Apache-2.0",
    "Apache 2.0",
    "BSD",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "ISC",
    "OFL-1.1",
    "MPL-2.0",
    "LGPL-2.1",
    "LGPL-3.0"
